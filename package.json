{
  "name": "n8n-nodes-bigip-f5",
  "version": "0.1.2",
  "description": "n8n community node for F5 BIG-IP iControl REST API",
  "license": "MIT",
  "homepage": "https://github.com/kboykov/n8n-nodes-bigip-f5",
  "keywords": [
    "n8n-community-node-package",
    "f5",
    "bigip",
    "big-ip",
    "ltm",
    "asm",
    "apm",
    "icontrol",
    "load-balancer",
    "waf",
    "network"
  ],
  "author": {
    "name": "Kristiyan Boykov",
    "email": "kboykov@protonmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kboykov/n8n-nodes-bigip-f5.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/BigIpF5Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/BigIpF5/BigIpF5.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.29.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "3.8.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
